# Innovate To Grow — environment configuration template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# `.env` is gitignored and must NOT be committed. All values below are
# required for the app to start (config/default.py reads them via os.getenv).

# --- Google Sheets ---
# Name of the spreadsheet to use. Tests are pinned to "Test I2G Membership".
CURRENT_SPREADSHEET=Test I2G Membership

# --- Gmail (SMTP / IMAP) ---
# Gmail address and a Google "app password" (not the account password).
MAIL_USERNAME=your-account@example.com
MAIL_PASSWORD=your-gmail-app-password

# --- Flask security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-random-secret
SECURITY_PASSWORD_SALT=change-me-random-salt

# --- AWS (SES / SQS) ---
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key

# --- Twilio (SMS / Verify) ---
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_NUMBER=+1XXXXXXXXXX
VERIFY_SID=your-twilio-verify-service-sid

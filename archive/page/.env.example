# Copy this file to `.env` and fill in real values:
#     cp .env.example .env
#
# Note: the project/schedule data pages read from Google Sheets using
# project/service_account.json (gitignored), not env vars.

# --- Flask security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-random-secret

# Innovate To Grow — environment configuration template
#
# Copy this file to `.env` and fill in real values:
#     cp .env.example .env

# --- Google Sheets ---
# The event pages call the Google Sheets API from the browser. This key is
# injected into the rendered HTML at request time (see project/__init__.py),
# so it is NOT stored in template source. It is still exposed to end users —
# that is unavoidable for a client-side key — so restrict it in the Google
# Cloud console to HTTP referrers (your domain) + the Sheets API only.
SHEETS_API_KEY=your-google-sheets-api-key

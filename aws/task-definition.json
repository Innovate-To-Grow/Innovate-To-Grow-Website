{
  "family": "itg-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "__ECS_EXECUTION_ROLE_ARN__",
  "taskRoleArn": "__ECS_TASK_ROLE_ARN__",
  "containerDefinitions": [
    {
      "name": "itg-backend",
      "image": "394167325273.dkr.ecr.us-west-2.amazonaws.com/itg-backend:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DJANGO_SETTINGS_MODULE",
          "value": "config.settings.production"
        },
        {
          "name": "DJANGO_ALLOWED_HOSTS",
          "value": "__DJANGO_ALLOWED_HOSTS__"
        },
        {
          "name": "DB_NAME",
          "value": "__DB_NAME__"
        },
        {
          "name": "DB_USER",
          "value": "__DB_USER__"
        },
        {
          "name": "DB_HOST",
          "value": "__DB_HOST__"
        },
        {
          "name": "DB_PORT",
          "value": "__DB_PORT__"
        },
        {
          "name": "DB_CONN_MAX_AGE",
          "value": "__DB_CONN_MAX_AGE__"
        },
        {
          "name": "DB_CONN_HEALTH_CHECKS",
          "value": "__DB_CONN_HEALTH_CHECKS__"
        },
        {
          "name": "WEB_CONCURRENCY",
          "value": "__WEB_CONCURRENCY__"
        },
        {
          "name": "UVICORN_LIMIT_CONCURRENCY",
          "value": "__UVICORN_LIMIT_CONCURRENCY__"
        },
        {
          "name": "CSRF_TRUSTED_ORIGINS",
          "value": "__CSRF_TRUSTED_ORIGINS__"
        },
        {
          "name": "CORS_ALLOWED_ORIGINS",
          "value": "__CORS_ALLOWED_ORIGINS__"
        },
        {
          "name": "FRONTEND_URL",
          "value": "__FRONTEND_URL__"
        },
        {
          "name": "BACKEND_URL",
          "value": "__BACKEND_URL__"
        },
        {
          "name": "AWS_STORAGE_BUCKET_NAME",
          "value": "__AWS_STORAGE_BUCKET_NAME__"
        },
        {
          "name": "AWS_S3_REGION_NAME",
          "value": "__AWS_S3_REGION_NAME__"
        },
        {
          "name": "DJANGO_SUPERUSER_USERNAME",
          "value": "__DJANGO_SUPERUSER_USERNAME__"
        },
        {
          "name": "DJANGO_SUPERUSER_EMAIL",
          "value": "__DJANGO_SUPERUSER_EMAIL__"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/itg-backend",
          "awslogs-region": "us-west-2",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "python -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/livez/')\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      },
      "essential": true,
      "secrets": [
        {
          "name": "DJANGO_SECRET_KEY",
          "valueFrom": "__DJANGO_SECRET_KEY_SECRET_ARN__"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "__DB_PASSWORD_SECRET_ARN__"
        },
        {
          "name": "REDIS_URL",
          "valueFrom": "__REDIS_URL_SECRET_ARN__"
        },
        {
          "name": "DJANGO_SUPERUSER_PASSWORD",
          "valueFrom": "__DJANGO_SUPERUSER_PASSWORD_SECRET_ARN__"
        }
      ]
    }
  ]
}

{
  "name": "pages",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size": "size-limit"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "dompurify": "^3.4.5",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "@vitest/coverage-v8": "^4.0.0",
    "size-limit": "^11.0.0",
    "@size-limit/file": "^11.0.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  },
  "size-limit": [
    { "path": "dist/assets/index-*.js", "limit": "200 kB", "gzip": true },
    { "path": "dist/assets/react-vendor-*.js", "limit": "65 kB", "gzip": true },
    { "path": "dist/assets/router-*.js", "limit": "35 kB", "gzip": true }
  ]
}

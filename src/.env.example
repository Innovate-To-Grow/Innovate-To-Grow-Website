# Django Settings
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=False

# Database Settings
DB_ENGINE=django.db.backends.postgresql
DB_NAME=innovate_to_grow
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# AWS Settings (required in production when using core.settings.prod)
AWS_STORAGE_BUCKET_NAME=your-production-bucket
# AWS_S3_REGION_NAME=us-west-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_ENDPOINT_URL=
# AWS_S3_CUSTOM_DOMAIN=

# Redis (Optional)
# REDIS_URL=redis://127.0.0.1:6379/1

# Frontend URL (for Live Preview)
# FRONTEND_URL=https://www.innovatetogrow.com

# Backend origin (required in production)
# BACKEND_URL=https://api.example.com

# Optional SES bounce/complaint webhook + campaign tagging (env-only, not in DB)
# SES_CONFIGURATION_SET_NAME=
# SES_SNS_TOPIC_ARN=

# Service credentials (Email, SMS, Google Sheets, AWS app keys) live in the
# database under Django admin → Site Settings. Configure them after `migrate`.
#   - Optional skeleton rows: python manage.py seed_service_configs
#   - Verify before prod deploy: python manage.py verify_service_configs --strict

# Dev seed admin (resetdb + createsuperuser fallback)
# DEV_ADMIN_EMAIL=admin@localhost
# DEV_ADMIN_PASSWORD=changeme
# DEV_ADMIN_USERNAME=admin

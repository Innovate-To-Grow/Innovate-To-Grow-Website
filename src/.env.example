# Django Settings
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DEBUG=False

# Database Settings
DB_ENGINE=django.db.backends.postgresql
DB_NAME=innovate_to_grow
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# AWS Settings (required in production when using core.settings.prod)
AWS_STORAGE_BUCKET_NAME=your-production-bucket
# AWS_S3_REGION_NAME=us-west-2
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_ENDPOINT_URL=
# AWS_S3_CUSTOM_DOMAIN=

# Redis (Optional)
# REDIS_URL=redis://127.0.0.1:6379/1

# Frontend URL (for Live Preview)
# FRONTEND_URL=https://www.innovatetogrow.com

# RSA Key Encryption
# When set, the RSA private key is encrypted at rest using this passphrase.
# Leave blank for development (keys stored unencrypted). Required in production.
RSA_KEY_PASSPHRASE=replace-me-in-production

# Google Sheets
# Option 1: Service account (preferred for production)
# GOOGLE_SHEETS_CREDENTIALS_JSON={"type":"service_account",...}
# GOOGLE_SHEETS_SCOPES=https://www.googleapis.com/auth/spreadsheets.readonly
# Option 2: API key (simpler, public read-only access)
# GOOGLE_SHEETS_API_KEY=your-api-key

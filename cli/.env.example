# i2g-admin CLI configuration.
#
# Copy this file to `.env` (which is gitignored) and adjust the value for your
# target backend. The CLI loads `.env` automatically; an exported shell variable
# of the same name takes precedence, and `i2g-admin configure --base-url <url>`
# can override it per machine.

# Base URL of the Innovate-To-Grow backend the CLI talks to.
# Must be https for any remote host; http is only allowed for loopback dev hosts.
#   Production:  https://api.i2g.ucmerced.edu/admin
#   Local dev:   http://127.0.0.1:8000
I2G_ADMIN_BASE_URL=https://api.i2g.ucmerced.edu/admin

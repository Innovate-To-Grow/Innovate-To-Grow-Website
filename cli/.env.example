# i2g-admin CLI configuration.
#
# Copy this file to `.env` (which is gitignored) and set the value for your
# target backend. The CLI loads `.env` automatically; an exported shell variable
# of the same name takes precedence, and `i2g-admin configure set base_url <url>`
# can override it per machine/profile.

# Base URL of the Innovate-To-Grow backend the CLI talks to.
# Must be https for any remote host; http is only allowed for loopback dev hosts.
# There is no baked-in default — set the deployment target here (or in the env).
I2G_ADMIN_BASE_URL=http://127.0.0.1:8000
